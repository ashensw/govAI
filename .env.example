# ---------------------------------------------------------------------------
# GovAI PoC — environment configuration
# Copy this file to .env and adjust values before running docker compose up
# ---------------------------------------------------------------------------

# --- Postgres (metadata: users, documents, chats, audit log) ---------------
POSTGRES_USER=govai
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=govai
DATABASE_URL=postgresql+psycopg://govai:change-me-in-production@postgres:5432/govai

# --- Qdrant (vector database) -----------------------------------------------
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=govai_documents

# --- Auth --------------------------------------------------------------------
# Generate a strong random value for production, e.g. `openssl rand -hex 32`
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# --- LLM provider --------------------------------------------------------
# One of: ollama | anthropic | openai_compatible
# "ollama" keeps every request on infrastructure you control (no external
# calls) and is the default for the sovereignty/privacy story. Switch to a
# hosted provider only when the data classification allows it.
LLM_PROVIDER=ollama

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b

# Only used when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Only used when LLM_PROVIDER=openai_compatible (OpenAI itself, vLLM,
# LM Studio, Azure OpenAI-compatible gateways, etc.)
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=gpt-4o-mini

# Kept low: grounded, cited QA over retrieved documents should stay
# faithful to the source text rather than sampling creatively. Raise it
# only if you specifically want more varied phrasing and accept the
# faithfulness tradeoff.
LLM_TEMPERATURE=0.1

# --- Embeddings (always local — never leaves the deployment) ---------------
EMBEDDING_MODEL=intfloat/multilingual-e5-base
EMBEDDING_DIM=768

# --- RAG pipeline tuning -----------------------------------------------------
CHUNK_SIZE_WORDS=220
CHUNK_OVERLAP_WORDS=40
RETRIEVAL_TOP_K=6

# --- Misc ---------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=25

# Seed admin account created on first startup (change immediately after login)
SEED_ADMIN_EMAIL=admin@govai.local
SEED_ADMIN_PASSWORD=ChangeMe123!
